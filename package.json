{
  "name": "curacel-expense-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack expense and invoice tracking bot — Phase 1.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "build:shared": "npm run build -w @curacel/shared",
    "build": "npm run build:shared && tsc -p tsconfig.json",
    "predev": "npm run build:shared",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "pretest": "npm run build:shared",
    "typecheck": "npm run build:shared && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "bootstrap-sheet": "tsx src/sheets/bootstrap.ts"
  },
  "dependencies": {
    "@curacel/shared": "*",
    "@slack/bolt": "^3.21.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "openai": "^4.65.0",
    "pdf-to-png-converter": "^4.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.2"
  }
}
