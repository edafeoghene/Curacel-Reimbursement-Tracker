# =============================================================================
# Bot (Phase 1) — required for the Slack expense bot
# =============================================================================

# Slack — bot user OAuth token (xoxb-...) and Socket Mode app-level token (xapp-...)
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_APP_TOKEN=xapp-REPLACE_ME

# OpenRouter — provider locked to anthropic in code (allow_fallbacks=false)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Google Sheets — workbook ID + base64'd service account JSON.
# Reused by the frontend (Wave 2.3) for read-only Sheets access.
GOOGLE_SHEETS_ID=REPLACE_ME
GOOGLE_SERVICE_ACCOUNT_B64=REPLACE_ME

# Slack channel + user IDs (sourced from sheet for approvers; manager is config).
# Frontend (Wave 2.5) reads EXPENSES_CHANNEL_ID for the file proxy.
EXPENSES_CHANNEL_ID=C0REPLACE_ME
FINANCIAL_MANAGER_USER_ID=U0REPLACE_ME

# OPTIONAL — Phase 1.7 read-only feed channel. Leave unset to disable.
EXPENSE_LOG_CHANNEL_ID=

# Runtime (bot only)
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# =============================================================================
# Frontend (Phase 2) — required for the FM dashboard (Next.js)
# =============================================================================

# NextAuth.js (Auth.js v5) — base URL + signing secret for JWT cookies
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=                          # generate via: openssl rand -hex 32

# Google OAuth client credentials (Google Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI must include http://localhost:3001/api/auth/callback/google
# for local dev (and the Vercel preview/prod URI when deploying).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of @curacel.ai emails allowed to sign in.
# Empty = nobody allowed (fail-closed default). Lowercase + trim happen at runtime.
ALLOWED_FM_EMAILS=
