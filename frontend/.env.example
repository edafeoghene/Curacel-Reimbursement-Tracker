# Frontend (FM dashboard) — read by Next.js, NOT by the bot.

# Auth (Wave 2.2)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=                          # openssl rand -hex 32
GOOGLE_CLIENT_ID=                          # Google Cloud Console → OAuth client
GOOGLE_CLIENT_SECRET=
ALLOWED_FM_EMAILS=                         # CSV, lowercased+trimmed at runtime

# Sheets (Wave 2.3) — read-only; reuses the bot's service account
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Slack file proxy (Wave 2.5) — server-side only, never exposed to the browser
SLACK_BOT_TOKEN=
EXPENSES_CHANNEL_ID=
